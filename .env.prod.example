# ══════════════════════════════════════════════════════════════════════
# Шаблон .env для VPS-деплоя. На сервере:
#   cp .env.prod.example .env   → заполнить все REPLACE_*
# Полная инструкция: docs/DEPLOY.md
#
# Генерация секретов:
#   JWT-секреты:      openssl rand -hex 64   (два разных!)
#   Пароли/ключи:     openssl rand -hex 32
# ══════════════════════════════════════════════════════════════════════

# Домен, на котором живёт КакДела. Нужны ДВЕ A-записи на IP VPS:
#   <домен>  и  s3.<домен>
KD_DOMAIN=kakdela.example.com

# === Speedy (backend) ===
NODE_ENV=production
SPEEDY_PORT=3001
SPEEDY_HOST=0.0.0.0
SPEEDY_LOG_LEVEL=info

# Postgres. Хост `postgres` — имя сервиса в docker-сети kd-net.
# Пароль должен совпадать с POSTGRES_PASSWORD ниже!
DATABASE_URL=postgres://kakdela:REPLACE_PG_PASSWORD@postgres:5432/kakdela

# Redis — тоже по имени сервиса.
REDIS_URL=redis://redis:6379

# Auth — два РАЗНЫХ длинных секрета (openssl rand -hex 64)
JWT_ACCESS_SECRET=REPLACE_openssl_rand_hex_64
JWT_REFRESH_SECRET=REPLACE_openssl_rand_hex_64_other
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# LiveKit. URL — публичный, через caddy (/livekit → livekit:7880):
# его же speedy отдаёт клиентам в ответе voice/join.
# ADMIN_URL — для серверного admin-API (twirp): speedy ходит в LiveKit
# напрямую по docker-сети, через публичный домен изнутри контейнера нельзя.
# KEY/SECRET должны совпадать с ops/livekit/livekit.prod.yaml → keys.
LIVEKIT_URL=wss://kakdela.example.com/livekit
LIVEKIT_ADMIN_URL=http://livekit:7880
LIVEKIT_API_KEY=kdprod
LIVEKIT_API_SECRET=REPLACE_openssl_rand_hex_32

# MinIO. Внутренний endpoint — для серверных операций speedy;
# публичный — для presigned-ссылок, которые открывают клиенты
# (поддомен s3.<домен> проксируется caddy → minio:9000).
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=https://s3.kakdela.example.com
S3_REGION=us-east-1
S3_BUCKET=kakdela
S3_EMOJI_BUCKET=kakdela-emoji
S3_ACCESS_KEY=kakdela
S3_SECRET_KEY=REPLACE_openssl_rand_hex_32

# Лимит custom emoji на сервер
EMOJI_PER_SERVER=50

# Public origin — для CORS и ссылок-инвайтов. Без слэша на конце.
PUBLIC_ORIGIN=https://kakdela.example.com

# === Polly (клиент) ===
# Запекаются в web-бандл при сборке kd-caddy (build args).
# Эти же значения нужны в packages/polly/.env.production при сборке
# desktop-.msi (см. docs/DEPLOY.md §8).
VITE_SPEEDY_URL=https://kakdela.example.com
VITE_SPEEDY_WS_URL=wss://kakdela.example.com/ws
VITE_LIVEKIT_URL=wss://kakdela.example.com/livekit

# === Postgres-контейнер (docker-compose.prod.yml) ===
POSTGRES_USER=kakdela
POSTGRES_PASSWORD=REPLACE_PG_PASSWORD
POSTGRES_DB=kakdela

# === Бэкапы (T-084) ===
BACKUP_RETENTION_DAYS=14
# Опциональный off-site: `user@host:/abs/path`. Пусто → выключен.
OFFSITE_RSYNC_TARGET=

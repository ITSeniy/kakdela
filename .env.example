# === Speedy (backend) ===
SPEEDY_PORT=3001
SPEEDY_HOST=0.0.0.0
SPEEDY_LOG_LEVEL=info

# Postgres
DATABASE_URL=postgres://kakdela:kakdela_dev@localhost:5433/kakdela

# Redis
REDIS_URL=redis://localhost:6379

# Auth (длинная случайная строка — сгенерируй: openssl rand -hex 64)
JWT_ACCESS_SECRET=51bbf0197d8d81c965edefec77fbc3c9744bb0659e791375b2dc69f2cf775e0d4d528907eb0e0c26fe0571974d910e2e39c0d3bb71b3b472e7585dbe4949495e
JWT_REFRESH_SECRET=5b216913f00e615a23411e7b9353b5e47fc865baf0a5cbaebd11bf5dfb2a8f632035fb60ec4dac6cc4e85b08a5979e056d632d24cb7e6ce9b7c3a6da5d94746e
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# LiveKit (см. ops/livekit/livekit.yaml — те же значения)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_replace_in_prod_replace_in_prod

# MinIO (S3-совместимое хранилище)
S3_ENDPOINT=http://localhost:9000
# Публичный endpoint для presigned-ссылок клиентам. В dev не нужен (равен
# S3_ENDPOINT); на VPS — https://s3.<домен>, см. .env.prod.example.
# S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=kakdela
S3_EMOJI_BUCKET=kakdela-emoji
S3_ACCESS_KEY=kakdela
S3_SECRET_KEY=kakdela_dev_secret

# Лимит custom emoji на сервер (T-081)
EMOJI_PER_SERVER=50

# Public origin для генерации ссылок-инвайтов и CORS
PUBLIC_ORIGIN=http://localhost:1420

# === Polly (desktop client) ===
# В dev — Vite слушает на 1420 (стандарт Tauri), prod — статика встроена в бинарь.
VITE_SPEEDY_URL=http://localhost:3001
VITE_SPEEDY_WS_URL=ws://localhost:3001/ws
VITE_LIVEKIT_URL=ws://localhost:7880

# === Prod-only (docker-compose.prod.yml) ===
# Дискретные креды для postgres-контейнера. В dev мы их не используем —
# DATABASE_URL содержит всё, и сам контейнер берёт значения из dev-compose.
POSTGRES_USER=kakdela
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=kakdela

# Бэкапы (T-084)
BACKUP_RETENTION_DAYS=14
# Опциональный off-site target: `user@host:/abs/path` или `rsync://...`.
# Пусто → off-site выключен, snapshot лежит только в локальном volume.
OFFSITE_RSYNC_TARGET=
